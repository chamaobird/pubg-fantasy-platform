# Deploy hooks do Render — copie este arquivo para .env.deploy e preencha
#
# Como obter as URLs:
#   1. Acesse https://dashboard.render.com
#   2. Clique no serviço (backend ou frontend)
#   3. Settings → Deploy Hook → copie a URL
#
RENDER_HOOK_BACKEND=https://api.render.com/deploy/srv-COLOQUE_AQUI?key=COLOQUE_AQUI
RENDER_HOOK_FRONTEND=https://api.render.com/deploy/srv-COLOQUE_AQUI?key=COLOQUE_AQUI
