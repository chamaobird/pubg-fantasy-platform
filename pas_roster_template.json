{
  "_instructions": {
    "how_to_use": [
      "1. Fill in the real pubg_id for each player (account.xxxxxxxx format).",
      "2. Get pubg_ids from: https://pubg.op.gg or https://liquipedia.net/pubg",
      "   Search by player name → profile page shows accountId in the URL or API.",
      "3. POST this JSON (the 'players' array) to:",
      "   POST /admin/players/bulk-upsert/{your_tournament_id}",
      "4. Then check: GET /admin/players/resolution-check/{your_tournament_id}",
      "   Aim for 100% before the event.",
      "5. pubg_id format is always: account. followed by 32 hex chars",
      "   Example: account.a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4"
    ],
    "where_to_find_pubg_ids": {
      "pubg_op_gg": "https://pubg.op.gg/search?query=PLAYERNAME",
      "liquipedia": "https://liquipedia.net/pubg/PLAYERNAME",
      "pubg_esports": "https://www.pubgesports.com",
      "note": "The accountId is exposed in the PUBG API when you fetch a match the player appeared in."
    }
  },
