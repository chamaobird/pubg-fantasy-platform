# .env.example — copie para .env e preencha os valores

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/warzone_fantasy

# JWT
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# PUBG API — obtenha em: https://developer.pubg.com/
PUBG_API_KEY=your-pubg-api-key-here
# Shard: pc-eu | pc-na | pc-as | pc-sea | pc-kakao | psn-eu | xbox-eu | ...
PUBG_SHARD=pc-tournament
